<%- include('partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-9">
        <article class="card shadow-sm mb-4">
            <div class="row g-0">
                <div class="col-md-1 d-flex flex-column align-items-center bg-light border-end py-4">
                    <form action="/posts/<%= post._id %>/vote" method="POST">
                        <input type="hidden" name="type" value="up">
                        <button type="submit" class="btn btn-sm <%= post.upvotes.includes(currentUser && currentUser._id) ? 'btn-primary' : 'btn-outline-secondary' %> mb-1">↑</button>
                    </form>
                    <span class="fw-bold"><%= post.upvotes.length - post.downvotes.length %></span>
                    <form action="/posts/<%= post._id %>/vote" method="POST">
                        <input type="hidden" name="type" value="down">
                        <button type="submit" class="btn btn-sm <%= post.downvotes.includes(currentUser && currentUser._id) ? 'btn-danger' : 'btn-outline-secondary' %> mt-1">↓</button>
                    </form>
                </div>
                <div class="col-md-11">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge badge-<%= post.tag %> text-dark me-2"><%= post.tag %></span>
                            <small class="text-muted">Posted by <a href="/users/<%= post.author.username %>" class="text-decoration-none fw-bold">u/<%= post.author.username %></a> • <%= post.createdAt.toLocaleString() %></small>
                        </div>
                        <h1 class="card-title fw-bold mb-3"><%= post.title %></h1>
                        <div class="card-text mb-4 lead" style="white-space: pre-wrap;"><%= post.body %></div>
                        
                        <% if (post.image) { %>
                            <div class="mb-4 text-center">
                                <img src="<%= post.image %>" class="img-fluid rounded border" alt="<%= post.title %>">
                            </div>
                        <% } %>

                        <% if (currentUser && post.author._id.equals(currentUser._id)) { %>
                            <div class="d-flex border-top pt-3">
                                <a href="/posts/<%= post._id %>/edit" class="btn btn-outline-secondary btn-sm me-2">Edit Post</a>
                                <form action="/posts/<%= post._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this post?');">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete Post</button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </article>

        <!-- Comments Section -->
        <div class="card shadow-sm mb-5">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4">Comments (<%= post.comments.length %>)</h5>
                
                <% if (currentUser) { %>
                    <form action="/posts/<%= post._id %>/comments" method="POST" class="mb-5">
                        <div class="mb-3">
                            <textarea class="form-control" name="body" rows="3" placeholder="What are your thoughts?" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm px-4">Post Comment</button>
                    </form>
                <% } else { %>
                    <div class="alert alert-light border mb-5 text-center">
                        <p class="mb-0">Please <a href="/auth/login">log in</a> to leave a comment.</p>
                    </div>
                <% } %>

                <div class="comment-list">
                    <% if (post.comments.length === 0) { %>
                        <p class="text-muted text-center py-4">No comments yet. Be the first!</p>
                    <% } %>
                    <% post.comments.sort((a,b) => b.createdAt - a.createdAt).forEach(comment => { %>
                        <div class="border-bottom mb-4 pb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <small class="fw-bold text-primary">u/<%= comment.author.username %> <span class="text-muted fw-normal mx-2">• <%= comment.createdAt.toLocaleString() %></span></small>
                                <% if (currentUser && comment.author._id.equals(currentUser._id)) { %>
                                    <form action="/posts/<%= post._id %>/comments/<%= comment._id %>?_method=DELETE" method="POST">
                                        <button type="submit" class="btn btn-link btn-sm text-danger p-0 text-decoration-none">Delete</button>
                                    </form>
                                <% } %>
                            </div>
                            <p class="mb-0"><%= comment.body %></p>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
